{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mihoyo-widget",
  "version": "0.1.0",
  "identifier": "com.mihoyo.widget",
  "build": {
    "frontendDist": "../../packages/frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../packages/frontend && npm run dev",
    "beforeBuildCommand": "cd ../packages/frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Mihoyo Widget",
        "width": 360,
        "height": 590,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data:; font-src 'self' data:; frame-src 'none'; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
